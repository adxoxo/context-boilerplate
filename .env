# ─────────────────────────────────────────────────────────────
# .env.local — boilerplate template
# Copy this into every new project. Never commit this file.
# Make sure .env.local is in your .gitignore.
# ─────────────────────────────────────────────────────────────

# ── Gemini (for extract_design_tokens.py) ─────────────────────
GEMINI_API_KEY=


# ── Django ────────────────────────────────────────────────────
DJANGO_SECRET_KEY=
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Django CORS (for Next.js frontend)
CORS_ALLOWED_ORIGINS=http://localhost:3000


# ── Supabase ──────────────────────────────────────────────────
# From: supabase.com → your project → Settings → API

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase DB direct connection (for Django ORM / migrations)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres


# ── Next.js ───────────────────────────────────────────────────
# NEXT_PUBLIC_ prefix = exposed to the browser (safe for anon keys only)
# No prefix = server-side only

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Your Django REST API base URL
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000


# ── Auth (if using Supabase Auth) ─────────────────────────────
# JWT secret must match your Supabase project's JWT secret
# From: supabase.com → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=


# ── Email (optional — add when needed) ───────────────────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# DEFAULT_FROM_EMAIL=


# ── Payments (optional — add when needed) ─────────────────────
# PayMongo (PH)
# PAYMONGO_SECRET_KEY=
# PAYMONGO_PUBLIC_KEY=
# NEXT_PUBLIC_PAYMONGO_PUBLIC_KEY=

# Stripe (if needed later)
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=


# ── Storage (optional — Supabase Storage is usually enough) ───
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION=
